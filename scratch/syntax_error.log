/* \n* Não revenda ou passe para alguém essa base.\n* Author: CORVO.\n* Apoio: CORVO.\n* Site api pra funcionar os downloads: https://corvoapis.site\n*/\n\nconst { GoogleGenerativeAI } = require("@google/generative-ai");\nconst { PDFDocument, StandardFonts, rgb } = require('pdf-lib');\nconst pdfParse = require('pdf-parse');\nconst googleIt = require('google-it');\n\nconst CONFIG_ADMIN = {\n    GOOGLE_API_KEYS: ["AIzaSyB4JXhqReVz_PXUyJwVIsTC6gRMNgrVn0Q", "", "", "", "", "", "", "", "", "", "", "", "", "", ""],\n    MODEL_PRIMARY: "gemini-1.5-flash",\n    MODEL_SECONDARY: "gemini-1.5-pro",\n    MODEL_TERTIARY: "gemini-pro"\n};\n\nglobal.aiEditMode = false;\n\nasync function callGeminiAI(prompt, mediaData = null, modelName = CONFIG_ADMIN.MODEL_PRIMARY) {\n    for (const key of CONFIG_ADMIN.GOOGLE_API_KEYS) {\n        if (!key) continue;\n        try {\n            const genAI = new GoogleGenerativeAI(key);\n            const model = genAI.getGenerativeModel({ model: modelName });\n            \n            let parts = [{ text: prompt }];\n            if (mediaData) {\n                parts.push({\n                    inlineData: {\n                        data: mediaData.data.toString("base64"),\n                        mimeType: mediaData.mimeType\n                    }\n                });\n            }\n\n            const result = await model.generateContent(parts);\n            const response = await result.response;\n            return response.text().trim();\n        } catch (e) {\n            console.error(`[AI-ERROR] Model ${modelName} failed with key:`, e.message);\n            if (e.message.includes("429") || e.message.includes("quota")) continue;\n            throw e;\n        }\n    }\n    throw new Error("Todas as chaves de API falharam ou atingiram o limite.");\n}\n\nasync function callGeminiWithFallback(prompt, mediaData = null) {\n    try { return await callGeminiAI(prompt, mediaData, CONFIG_ADMIN.MODEL_PRIMARY); }\n    catch (e) {\n        try { return await callGeminiAI(prompt, mediaData, CONFIG_ADMIN.MODEL_SECONDARY); }\n        catch (e2) { return await callGeminiAI(prompt, mediaData, CONFIG_ADMIN.MODEL_TERTIARY); }\n    }\n}\n\nasync function startcorvo(upsert, corvo, qrcode) {\n    try {\n      var info = upsert.messages[0];\n      if (!info.message) return;\n      \n      console.log('[UPSERT-DEBUG] De:', info.key.remoteJid, 'Type:', upsert.type);\n      \n      async function startFunctionNaga() {\n        var ownerNumber = setting.ownerNumber.replace(new RegExp("[()+-/ +/]", "gi"), "")\n        for (var info of upsert?.messages || []) {\n          var from = info.key.remoteJid;\n          var isGroup = from.endsWith('@g.us');\n          var isSabCityOFF = isRpgOn(from);\n          var isStatus = from.endsWith('@broadcast');\n\n        // ===== Proteção de ADM (por grupo) =====\n        var protFile = (gp) => `./DADOS DO CORVO/grupos/PROT_ADM/${gp}.json`;\n\n        function ensureProtFile(gp) {\n          var dir = `./DADOS DO CORVO/grupos/PROT_ADM`;\n          if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });\n          var file = protFile(gp);\n          if (!fs.existsSync(file)) fs.writeFileSync(file, JSON.stringify({ users: [] }, null, 2));\n          return file;\n        }\n\n        function getProtList(gp) {\n          try {\n            var file = ensureProtFile(gp);\n            var json = JSON.parse(fs.readFileSync(file));\n            if (!json.users) json.users = [];\n            return json;\n          } catch {\n            return { users: [] };\n          }\n        }\n\n        function setProtList(gp, json) {\n          var file = ensureProtFile(gp);\n          fs.writeFileSync(file, JSON.stringify(json, null, 2));\n        }\n\n        // Função auxiliar para resolver LID→JID usando participantes do grupo\n        var normJid = (jid, participants) => {\n          if (!jid) return jid;\n          if (jid.includes('@lid')) {\n            // Se tiver o formato :XX@lid, preservar para operações de protocolo, mas limpar para busca\n            var lidLimpo = jid.replace(/:.*(?=@)/, '');\n            // 1. Cache global\n            if (global.lidCache && global.lidCache[lidLimpo]) return global.lidCache[lidLimpo];\n            // 2. Metadata\n            if (participants && Array.isArray(participants)) {\n              for (var p of participants) {\n                var pLid = (p.lid || '').replace(/:.*(?=@)/, '');\n                var pId = (p.id || '').replace(/:.*(?=@)/, '');\n                if ((pLid && pLid === lidLimpo) || (pId && pId === lidLimpo)) {\n                  var campos = [p.phoneNumber, p.id, p.jid, p.participant];\n                  for (var campo of campos) {\n                    if (campo && typeof campo === 'string' && campo.includes('@s.whatsapp.net')) {\n                      return campo.replace(/:.*(?=@)/, '');\n                    }\n                  }\n                }\n              }\n            }\n            // NÃO criar fake - manter @lid\n            return lidLimpo;\n          }\n          return jid;\n        };\n\n        // CORREÇÃO GLOBAL: Resolver LID para número real de telefone (para exibição)\n        var resolverNumeroReal = (jid, participants) => {\n          if (!jid) return '';\n          // 1. Cache global\n          if (jid.includes('@lid')) {\n            var lidLimpo = jid.replace(/:.*(?=@)/, '');\n            if (global.lidCache && global.lidCache[lidLimpo]) {\n              return global.lidCache[lidLimpo].split('@')[0];\n            }\n          }\n          var resolved = jid;\n          if (jid.includes('@lid') && participants && Array.isArray(participants)) {\n            var lidLimpo2 = jid.replace(/:.*(?=@)/, '');\n            for (var p of participants) {\n              var pLid = (p.lid || '').replace(/:.*(?=@)/, '');\n              var pId = (p.id || '').replace(/:.*(?=@)/, '');\n              if ((pLid && pLid === lidLimpo2) || (pId && pId === lidLimpo2)) {\n                var campos = [p.phoneNumber, p.id, p.jid, p.participant];\n                for (var campo of campos) {\n                  if (campo && typeof campo === 'string' && campo.includes('@s.whatsapp.net')) {\n                    resolved = campo.replace(/:.*(?=@)/, '');\n                    break;\n                  }\n                }\n                if (resolved === jid && p.phoneNumber) {\n                  return String(p.phoneNumber).replace(/[^0-9]/g, '');\n                }\n                break;\n              }\n            }\n          }\n          return resolved.split('@')[0];\n        };\n\n        // Resolver nome real de um participante\n        var resolverNomeReal = (jid, participants, fallbackName) => {\n          if (!jid) return fallbackName || '';\n          if (participants && Array.isArray(participants)) {\n            var jidLimpo = jid.replace(/:.*(?=@)/, '');\n            for (var p of participants) {\n              var pIds = [p.id, p.jid, p.lid, p.phoneNumber, p.participant]\n                .filter(Boolean).map(x => x.replace(/:.*(?=@)/, ''));\n              if (pIds.includes(jidLimpo) || pIds.some(x => x.split('@')[0] === jidLimpo.split('@')[0])) {\n                if (p.notify) return p.notify;\n                if (p.name) return p.name;\n                if (p.subject) return p.subject;\n                var campos = [p.phoneNumber, p.id, p.jid, p.participant];\n                for (var campo of campos) {\n                  if (campo && typeof campo === 'string' && campo.includes('@s.whatsapp.net')) {\n                    return campo.replace(/:.*(?=@)/, '').split('@')[0];\n                  }\n                }\n              }\n            }\n          }\n          return fallbackName || jid.split('@')[0];\n        };\n        // ====== CACHE GLOBAL LID ↔ PHONE (persistente) ======\n        if (!global.lidCache) {\n          try { global.lidCache = JSON.parse(fs.readFileSync('./DADOS DO CORVO/data/lid_cache.json')); } catch { global.lidCache = {}; }\n        }\n        // Aprender mapeamento LID→Phone de cada mensagem recebida\n        var _msgPart = info?.key?.participant || '';\n        var _msgPartPn = info?.key?.participantPn || info?.key?.senderPn || info?.key?.participantAlt || '';\n        if (_msgPart.includes('@lid') && _msgPartPn.includes('@s.whatsapp.net')) {\n          var _lidKey = _msgPart.replace(/:.*(?=@)/, '');\n          var _phoneVal = _msgPartPn.replace(/:.*(?=@)/, '');\n          if (!global.lidCache[_lidKey] || global.lidCache[_lidKey] !== _phoneVal) {\n            global.lidCache[_lidKey] = _phoneVal;\n            global.lidCacheDirty = (global.lidCacheDirty || 0) + 1;\n            if (global.lidCacheDirty >= 5) {\n              try { fs.writeFileSync('./DADOS DO CORVO/data/lid_cache.json', JSON.stringify(global.lidCache, null, 2)); } catch {}\n              global.lidCacheDirty = 0;\n            }\n          }\n        }\n        // Função global para resolver LID → Phone usando cache\n        var resolverLid = (lid) => {\n          if (!lid) return lid;\n          if (!lid.includes('@lid')) return lid;\n          var limpo = lid.replace(/:.*(?=@)/, '');\n          if (global.lidCache && global.lidCache[limpo]) return global.lidCache[limpo];\n          return limpo;\n        };\n\n        if (!global.messageStore) global.messageStore = {}\n        if (!info.key.fromMe && info.key?.id) {\n          messageStore[info.key.id] = info\n        }\n        // Garantir que mensagens de pagamento sejam sempre armazenadas para o comando d/del\n        if (info.key?.id) {\n          var strCheck = JSON.stringify(info.message || {});\n          if (strCheck.includes('Payment') || strCheck.includes('payment') || strCheck.includes('currencyCode') || strCheck.includes('amount1000')) {\n            messageStore[info.key.id] = info\n            global.messageStore[info.key.id] = info\n          }\n        }\n        if (info.message?.protocolMessage?.key?.id) {\n          var proto = info.message.protocolMessage\n          var type = proto.type\n          if (type !== 0 && type !== 14) return\n          try {\n            var key = proto.key\n            var remoteJid = key.remoteJid\n            var msgId = key.id\n            var participant = key.participant\n            if (!remoteJid?.endsWith('@g.us')) return\n            var pathGp = `./DADOS DO CORVO/grupos/${remoteJid}.json`\n            if (!fs.existsSync(pathGp)) return\n            var dataGp = JSON.parse(fs.readFileSync(pathGp))\n            if (!dataGp[0]?.antidelete) return\n            var original = messageStore[msgId]\n            if (!original) return\n            if (info.key.fromMe) return\n            var metadata = await corvo.groupMetadata(remoteJid)\n            var admins = metadata.participants\n              .filter(p => p.admin)\n              .map(p => p.id || p.jid)\n            var user = original.key.participant || participant\n            //    if (!user || admins.includes(user)) return\n            var userName = original.pushName || user.split('@')[0]\n            var profilePic = imgperfil\n            try {\n              profilePic = await corvo.profilePictureUrl(user, 'image')\n            } catch { }\n            var extractText = (m) => {\n              if (!m) return ''\n              if (m.conversation) return m.conversation\n              if (m.extendedTextMessage?.text) return m.extendedTextMessage.text\n              if (m.imageMessage?.caption) return m.imageMessage.caption\n              if (m.videoMessage?.caption) return m.videoMessage.caption\n              if (m.documentMessage?.caption) return m.documentMessage.caption\n              return ''\n            }\n            if (type === 0) {\n              if (original.message.conversation || original.message.extendedTextMessage) {\n                await corvo.sendMessage(remoteJid, { text: extractText(original.message), contextInfo: { mentionedJid: [user], externalAdReply: { title: '🚨 MENSAGEM APAGADA', body: `Por: ${userName}`, mediaType: 2, thumbnailUrl: profilePic } } })\n              } else {\n                await corvo.sendMessage(remoteJid, { forward: { key: original.key, message: original.message }, contextInfo: { mentionedJid: [user], externalAdReply: { title: '🚨 MENSAGEM APAGADA', body: `Por: ${userName}`, mediaType: 2, thumbnailUrl: profilePic } } })\n              }\n              delete messageStore[msgId]\n            }\n            if (type === 14) {\n              var oldText = extractText(original.message)\n              var editedMsg = proto.editedMessage?.message || proto.editedMessage || proto.editedMessage?.conversation || proto.editedMessage?.extendedTextMessage || proto.editedMessage?.imageMessage || proto.editedMessage?.videoMessage\n              var newText = extractText(editedMsg?.message ? editedMsg.message : editedMsg) || extractText(info.message) || ''\n              var textoFinal = `💢 *𝐌𝐄𝐍𝐒𝐀𝐆𝐄𝐌 𝐄𝐃𝐈𝐓𝐀𝐃𝐀*\n- 𝙿𝙾𝚁: @${user.split('@')[0]}\n\n> 🕓 *𝙰𝙽𝚃𝙴𝚂:*\n- ${oldText || '(sem texto/legenda)'}\n> 👀 *𝙳𝙴𝙿𝙾𝙸??:*\n- ${newText || '(sem texto/legenda)'}`\n              await corvo.sendMessage(remoteJid, { text: textoFinal, contextInfo: { mentionedJid: [user], externalAdReply: { title: '✏️ MENSAGEM EDITADA', body: `Por: ${userName}`, mediaType: 2, thumbnailUrl: profilePic } } })\n              messageStore[msgId] = {\n                ...original,\n                message: editedMsg?.message ? editedMsg.message : editedMsg || original.message\n              }\n            }\n\n          } catch (e) {\n            console.log('[ANTI SYSTEM ERROR]', e)\n          }\n        }\n        var VRF_JSON_GRUPO = fs.existsSync(`./DADOS DO CORVO/grupos/ATIVAÇÕES-CORVO/${from}.json`) ? true : false;\n\n        if (VRF_JSON_GRUPO) {\n          var jsonGp = JSON.parse(fs.readFileSync(`./DADOS DO CORVO/grupos/ATIVAÇÕES-CORVO/${from}.json`));\n        }\n\n        function createPaymentDetails(text, mentionedJidArray, participant) {\n          return {\n            requestPaymentMessage: {\n              currencyCodeIso4217: "BRL",\n              amount1000: "100000000000000000",\n              noteMessage: {\n                extendedTextMessage: {\n                  text,\n                  contextInfo: {\n                    mentionedJid: [...mentionedJidArray, participant],\n                    forwardingScore: 999,\n                    isForwarded: true\n                  }\n                }\n              },\n              expiryTimestamp: "0",\n              amount: {\n                value: "100000000000000000",\n                offset: 100000000000000000,\n                currencyCode: "BRL"\n              }\n            }\n          };\n        }\n\n        var CORVO = (texto, mentions = []) => ({\n          requestPaymentMessage: {\n            currencyCodeIso4217: "BRL",\n            amount1000: "1000",\n            noteMessage: {\n              extendedTextMessage: {\n                text: texto,\n                contextInfo: {\n                  mentionedJid: mentions,\n                  forwardingScore: 999,\n                  isForwarded: true\n                }\n              }\n            },\n            expiryTimestamp: "0",\n            amount: {\n              value: "1000",\n              offset: 1000,\n              currencyCode: "BRL"\n            }\n          }\n        });\n\n        function gerarContextNewsletter() {\n          if (setting.channelnk === "0@newsletter") {\n            return {};\n          }\n          return { isForwarded: true, forwardingScore: 1, forwardedNewsletterMessageInfo: { newsletterJid: setting.channelnk, newsletterName: NomeDoBot, serverMessageId: '', } }\n        }\n\n        if (VRF_JSON_GRUPO && jsonGp[0].x9 && info.messageStubType) {\n          var horarioAtual = new Date(info.messageTimestamp * 1000).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\n\n          switch (info.messageStubType) {\n            case 29: {\n              if (info.messageStubParameters?.length) {\n                var promovidoRaw = info.messageStubParameters[0];\n                var promotorRaw = info.participant;\n                var promovido = normalizeJid(promovidoRaw, groupMetadata?.participants);\n                var promotor = normalizeJid(promotorRaw, groupMetadata?.participants);\n                var msg = `*⚠️ 𝐀𝐋𝐄𝐑𝐓𝐀 𝐃𝐄 𝐏𝐑𝐎𝐌𝐎𝐂𝐀𝐎 ⚠️*\n\n*ᴏ ᴜsᴜᴀʀɪᴏ @${promovido.split("@")[0]} ꜰᴏɪ ᴘʀᴏᴍᴏᴠɪᴅᴏ ᴀ ᴀᴅᴍ. 🙆‍♂️*\n\n*ᴀᴅᴍ ʀᴇsᴘᴏɴsᴀ́ᴠᴇʟ: @${promotor.split("@")[0]} 🙅‍♂️*\n\n*ᴅᴀᴛᴀ: ${horarioAtual}*`;\n                var detalhes = createPaymentDetails(msg, [promovido], promotor);\n                await corvo.relayMessage(from, detalhes, {});\n              }\n            }\n              break;\n\n            case 30: {\n              if (info.messageStubParameters?.length) {\n                var rebaixadoRaw = info.messageStubParameters[0];\n                var rebaixadorRaw = info.participant;\n                var rebaixado = normalizeJid(rebaixadoRaw, groupMetadata?.participants);\n                var rebaixador = normalizeJid(rebaixadorRaw, groupMetadata?.participants);\n                var msg = `*⚠️ 𝐀𝐋𝐄𝐑𝐓𝐀 𝐃𝐄 𝐑𝐄𝐁𝐀𝐈𝐗𝐀𝐌𝐄𝐍𝐓𝐎 ⚠️*\n\n*ᴏ ᴜsᴜᴀʀɪᴏ @${rebaixado.split("@")[0]} ꜰᴏɪ ʀᴇʙᴀɪxᴀᴅᴏ ᴀ ᴍᴇᴍʙʀᴏ. 🤷‍♂️*\n\n*ᴀᴅᴍ ʀᴇsᴘᴏɴsᴀ́ᴠᴇʟ: @${rebaixador.split("@")[0]} 🙅‍♂️*\n\n*ᴅᴀᴛᴀ: ${horarioAtual}*`;\n                var detalhes = createPaymentDetails(msg, [rebaixado], rebaixador);\n                await corvo.relayMessage(from, detalhes, {});\n              }\n            }\n              break;\n          }\n        }\n\n        if (!info.message) return;\n        if (upsert.type == "append") return;\n        var baileys = require('@itsliaaa/baileys');\n        var type = baileys.getContentType(info.message);\n        var content = JSON.stringify(info.message);\n        var pushname = info.pushName ? info.pushName : '';\n\n        if (visualizarmsg) {\n          await corvo.readMessages([info.key]);\n        } else {\n          if (from == "status@broadcast") return;\n        }\n\n        //==============(BODY)================\\\n\n        function extrairTexto(info) {\n          var paths = ['message.conversation', 'message.sendPaymentMessage.noteMessage.extendedTextMessage.text', 'message.requestPaymentMessage.noteMessage.extendedTextMessage.text', 'message.viewOnceMessageV2.message.imageMessage.caption', 'message.viewOnceMessageV2.message.videoMessage.caption', 'message.imageMessage.caption', 'message.videoMessage.caption', 'message.extendedTextMessage.text', 'message.viewOnceMessage.message.videoMessage.caption', 'message.viewOnceMessage.message.imageMessage.caption', 'message.documentWithCaptionMessage.message.documentMessage.caption', 'message.buttonsMessage.imageMessage.caption', 'message.buttonsResponseMessage.selectedButtonId', 'message.listResponseMessage.singleSelectReply.selectedRowId', 'message.templateButtonReplyMessage.selectedId', 'message.pollCreationMessageV3.name', 'message.editedMessage.message.protocolMessage.editedMessage.extendedTextMessage.text', 'message.editedMessage.message.protocolMessage.editedMessage.imageMessage.caption', 'text', 'message.interactiveResponseMessage.nativeFlowResponseMessage.paramsJson'];\n\n          for (var path of paths) {\n            var value = path.split('.').reduce((obj, key) => obj?.[key], info);\n            if (value) {\n              if (path.includes('paramsJson')) {\n                try {\n                  return JSON.parse(value)?.id || '';\n                } catch {\n                  return '';\n                }\n              }\n              return value;\n            }\n          }\n\n          return '';\n        }\n\n        var body = extrairTexto(info);\n        var Procurar_String = body;\n        var budy2 = body.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, "");\n\n        if (isGroup && fs.existsSync(`./DADOS DO CORVO/grupos/ATIVAÇÕES-CORVO/${from}.json`) && jsonGp[0].multiprefix) {\n          var prefix = jsonGp[0]?.pre