r] }, { quoted: selo })\n            await SYSTEM_COIN.AdicionarCoins(sender, 5);\n            fs.unlinkSync(`./DADOS DO CORVO/grupos/games/enigma/${from}.json`)\n            setTimeout(async () => {\n              fs.writeFileSync(`./DADOS DO CORVO/grupos/games/enigma/${from}.json`, `${JSON.stringify(enigmaArchive[Math.floor(Math.random() * enigmaArchive.length)])}`)\n              enigmaD = JSON.parse(fs.readFileSync(`./DADOS DO CORVO/grupos/games/enigma/${from}.json`))\n              enigmaTezt = mess.respondeE(enigmaD, prefix)\n              wew = await getBuffer(rvenigma)\n              await corvo.sendMessage(from, { image: wew, caption: enigmaTezt }, { quoted: selo })\n            }, 5000)\n          }\n        }\n\n        if (isGroup && fs.existsSync(`./DADOS DO CORVO/grupos/games/wmusic/${from}.json`)) {\n          whatMusic = JSON.parse(fs.readFileSync(`./DADOS DO CORVO/grupos/games/wmusic/${from}.json`))\n          if (budy.slice(0, 4).toUpperCase() == whatMusic.resposta.slice(0, 4).toUpperCase() && budy.toUpperCase() != whatMusic.resposta) return reply('Tá perto hein! Tente novamente...')\n          if (budy.toUpperCase() == whatMusic.resposta) {\n            corvo.sendMessage(from, { text: mess.whatmusic(whatMusic, pushname) }, { "mentionedJid": [sender] }, { quoted: selo }); fs.unlinkSync(`./DADOS DO CORVO/grupos/games/wmusic/${from}.json`);\n            setTimeout(async () => {\n              fs.writeFileSync(`./DADOS DO CORVO/grupos/games/wmusic/${from}.json`, `${JSON.stringify(whatMusicAr[Math.floor(Math.random() * whatMusicAr.length)])}`)\n              wmusic = JSON.parse(fs.readFileSync(`./DADOS DO CORVO/grupos/games/wmusic/${from}.json`))\n              textM = mess.wmusic(wmusic, II)\n              await corvo.sendMessage(from, { text: textM }, { quoted: selo })\n            }, 5000)\n          }\n        }\n\n        if (isX9VisuUnica) {\n          if (info.message?.viewOnceMessageV2 || type === "viewOnceMessage") {\n            var px;\n            if (JSON.stringify(info).includes("videoMessage")) {\n              px = info.message?.viewOnceMessageV2?.message?.videoMessage ||\n                info.message?.viewOnceMessage?.message?.videoMessage;\n              if (px) {\n                px.viewOnce = false;\n                px.video = { url: px.url };\n                px.caption = (px.caption || "") + "\n\n";\n                await corvo.sendMessage(from, px, { quoted: selo });\n              }\n            } else if (JSON.stringify(info).includes("imageMessage")) {\n              px = info.message?.viewOnceMessageV2?.message?.imageMessage ||\n                info.message?.viewOnceMessage?.message?.imageMessage;\n              if (px) {\n                px.viewOnce = false;\n                px.image = { url: px.url };\n                px.caption = (px.caption || "") + "\n\n";\n                await corvo.sendMessage(from, px, { quoted: selo });\n              }\n            } else if (JSON.stringify(info).includes("audioMessage") ||\n              info.message?.extendedTextMessage?.contextInfo?.quotedMessage?.viewOnceMessageV2Extension?.message?.audioMessage) {\n              var audio = info.message?.viewOnceMessageV2?.message?.audioMessage ||\n                info.message?.viewOnceMessage?.message?.audioMessage;\n\n              if (audio && audio.mimetype) {\n                var buffAudio = await getFileBuffer(audio, 'audio');\n                var audioFile = getRandom('.mp3');\n                fs.writeFileSync(audioFile, buffAudio);\n                var audioBuffer = fs.readFileSync(audioFile);\n\n                await corvo.sendMessage(from, {\n                  audio: audioBuffer,\n                  mimetype: 'audio/mpeg',\n                  ptt: false\n                }, { quoted: selo });\n\n                fs.rmSync(audioFile);\n              }\n            }\n          }\n        }\n\n        //INICIO DE COMANDOS DE FECHAR E ABRIR GRUPO NO HORÁRIO PROGRAMADO!!\n\n        var horarios = {};\n        var horariosPath = './ARQUIVES/tictactoe/grupo.json';\n\n        if (fs.existsSync(horariosPath)) {\n          try {\n            horarios = JSON.parse(fs.readFileSync(horariosPath));\n          } catch (e) {\n            console.error('erro ao carregar horarios:', e);\n            horarios = {};\n          }\n        }\n\n        var salvarHorarios = () => {\n          fs.writeFileSync(horariosPath, JSON.stringify(horarios, null, 2));\n        };\n\n        var definirFechamento = (from, horario) => {\n          horarios[from] = horarios[from] || {};\n          horarios[from].fechamento = horario;\n          salvarHorarios();\n        };\n\n        var definirAbertura = (from, horario) => {\n          horarios[from] = horarios[from] || {};\n          horarios[from].abertura = horario;\n          salvarHorarios();\n        };\n\n        var removerHorarios = (from) => {\n          if (horarios[from]) {\n            delete horarios[from];\n            salvarHorarios();\n          }\n        };\n\n        var ultimaExecucao = {};\n\n        if (global.intervalHorarios) clearInterval(global.intervalHorarios);\n\n        global.intervalHorarios = setInterval(async () => {\n          var time2 = moment().tz('America/Sao_Paulo').format('HH:mm:ss');\n\n          if (fs.existsSync(horariosPath)) {\n            try {\n              horarios = JSON.parse(fs.readFileSync(horariosPath));\n            } catch (e) {\n              console.error(e);\n              horarios = {};\n            }\n          }\n\n          for (var from in horarios) {\n            var horario = horarios[from];\n            if (!horario) continue;\n\n            try {\n              if (horario.fechamento && time2 === horario.fechamento) {\n                if (ultimaExecucao[from + '_fechamento'] !== horario.fechamento) {\n                  await corvo.groupSettingUpdate(from, 'announcement');\n                  await corvo.sendMessage(from, {\n                    text: mess.abertura()\n                  });\n                  ultimaExecucao[from + '_fechamento'] = horario.fechamento;\n                }\n              }\n\n              if (horario.abertura && time2 === horario.abertura) {\n                if (ultimaExecucao[from + '_abertura'] !== horario.abertura) {\n                  await corvo.groupSettingUpdate(from, 'not_announcement');\n                  await corvo.sendMessage(from, {\n                    text: mess.fechamento(horario)\n                  });\n                  ultimaExecucao[from + '_abertura'] = horario.abertura;\n                }\n              }\n            } catch (e) {\n              console.error(e);\n            }\n          }\n        }, 1000);\n\n        async function sendMenu(from, selo, opt = {}) {\n          var {\n            reaction = "⚡", caption = mess.error(), isGroupRequired = false, isAdminRequired = false, isOwnerRequired = false, isModoCoinsRequired = false, isModoBnRequired = false, sendAudio = false } = opt;\n          try {\n            reagir(from, reaction);\n            if (isGroupRequired && !isGroup) return reply(mess.onlyGroup());\n            if (isAdminRequired && !isGroupAdmins && !SoDono) return reply(mess.onlyAdmins());\n            if (isOwnerRequired && !SoDono) return reply(mess.onlyOwner());\n            if (isModoCoinsRequired && !isModoCoins) return reply(`*ᴇssᴇ ᴄᴏᴍᴀɴᴅᴏ só ᴘᴏᴅᴇ sᴇʀ ᴀᴛɪᴠᴏ ǫᴜᴀɴᴅᴏ ᴏ sɪᴛᴇᴍᴀ ${prefix}ᴍᴏᴅᴏᴄᴏɪɴs ᴇsᴛɪᴠᴇʀ ᴀᴛɪᴠᴏ.*`);\n            if (isModoBnRequired && !isModobn) return reply(mess.onlyGroupFun(prefix));\n            if (sendAudio && isAudioMenu) await sendAudioMenu(from);\n            var midia = carregarMidia("fotomenu");\n            var msg = { caption, contextInfo: { ...NkChannelKk } };\n            if (midia.type === "video") {\n              msg.video = midia.data;\n              msg.gifPlayback = true;\n            } else if (midia.type === "image") {\n              msg.image = midia.data;\n            } else {\n              msg.text = caption;\n            }\n            await corvo.sendMessage(from, msg, { quoted: selo });\n          } catch (e) {\n            console.error(e);\n            await corvo.sendMessage(from, { text: caption, contextInfo: { ...NkChannelKk } }, { quoted: selo });\n          }\n        }\n\n\n        if (isAutoDl && isGroup && !info.key.fromMe) {\n\n          if (typeof body === 'string' && !body.startsWith(prefix)) {\n\n            /* =======================\n               🎵 TIKTOK AUTO DL\n            ======================== */\n\n            var tiktokMatch = body.match(/https?:\/\/(?:www\.|vm\.|vt\.)?tiktok\.com\/[^\s]+/i);\n\n            if (tiktokMatch) {\n              try {\n\n                var link = tiktokMatch[0]\n\n                var url = `https://corvoapis.site/api/downloads/tiktok-mp4?apitoken=${TOKEN}&url=${encodeURIComponent(link)}`\n\n                await corvo.sendMessage(from, {\n                  video: { url },\n                  mimetype: "video/mp4",\n                  fileName: "tiktok.mp4",\n                  caption: "🎵 Vídeo TikTok",\n                  contextInfo: NkChannelKk\n                }, { quoted: selo })\n\n                return\n\n              } catch (e) {\n                console.log("Erro Auto TikTok:", e.message)\n                return\n              }\n            }\n\n            /* =======================\n               📸 INSTAGRAM AUTO DL\n            ======================== */\n\n            var instaMatch = body.match(/https?:\/\/(?:www\.)?instagram\.com\/[^\s]+/i);\n\n            if (instaMatch) {\n              try {\n\n                var link = instaMatch[0]\n\n                var url = `https://corvoapis.site/api/downloads/instagram-video?apitoken=${TOKEN}&url=${encodeURIComponent(link)}`\n\n                await corvo.sendMessage(from, {\n                  video: { url },\n                  mimetype: "video/mp4",\n                  fileName: "instagram.mp4",\n                  contextInfo: NkChannelKk\n                }, { quoted: selo })\n\n                return\n\n              } catch (e) {\n                console.log("Erro Auto Instagram:", e.message)\n                return\n              }\n            }\n\n          }\n        }\n\n        /////\\\\\\//////\\\\\\////\\\\////\\\///\\\///\\\\\n\n        if (isCmd && isBanned) return reply(mess.bannedUser())\n\n        var totalhit = JSON.parse(fs.readFileSync('./DADOS DO CORVO/data/totalcmd.json'))\n        var CmdUsedBOT = () => {\n          totalhit[0].totalcmd += 1\n          fs.writeFileSync('./DADOS DO CORVO/data/totalcmd.json', JSON.stringify(totalhit))\n        }\n        if (isCmd) CmdUsedBOT()\n\n        var reqcmd = JSON.parse(fs.readFileSync('./DADOS DO CORVO/data/totalcmd.json'))\n\n        if (isGroup && isCmd && !isGroupAdmins && !SoDono && !isVip && dataGp[0]?.Limitar_CMD) {\n          var TEMPO_A = Math.floor(Date.now() / 1000)\n          var ID_G = Limit_CMD.findIndex(i => i.idgp === from)\n          var ID_U = Limit_CMD[ID_G]?.ids.findIndex(i => i.id === sender)\n          if (!JSON.stringify(Limit_CMD).includes(from) || ID_G < 0 && ID_U < 0) {\n            Limit_CMD.push({ idgp: from, ids: [{ id: sender, tempo: TEMPO_A }] })\n            fs.writeFileSync("./DADOS DO CORVO/func/limitarcmd.json", JSON.stringify(Limit_CMD, null, 2));\n          } else if (ID_G >= 0 && ID_U < 0) {\n            Limit_CMD[ID_G].ids.push({ id: sender, tempo: TEMPO_A })\n            fs.writeFileSync("./DADOS DO CORVO/func/limitarcmd.json", JSON.stringify(Limit_CMD, null, 2));\n          }\n\n          if (ID_G >= 0 && ID_U >= 0) {\n            var TEMPO_D = Limit_CMD[ID_G].ids[ID_U].tempo;\n            var TEMPO_M = TEMPO_A - TEMPO_D\n            var TEMPO_D2 = parseInt(dataGp[0]?.Limit_tempo) || 60\n            if (TEMPO_M < TEMPO_D2) {\n              return reply(nescessario.TEMPO_DE_CMD.replaceAll("#tempocmd#", TimeCount(TEMPO_M)).replaceAll("#tempo#", TEMPO_D2))\n            } else {\n              Limit_CMD[ID_G].ids[ID_U].tempo = TEMPO_A\n              fs.writeFileSync("./DADOS DO CORVO/func/limitarcmd.json", JSON.stringify(Limit_CMD, null, 2));\n            }\n          }\n        }\n\n        corvo.sendImageAsSticker = async (jid, path, options = {}) => {\n          var buff = Buffer.isBuffer(path) ? path : /^data:.*?\/.*?;base64,/i.test(path) ? Buffer.from(path.split`,`[1], 'base64') : /^https?:\/\//.test(path) ? await (await getBuffer(path)) : fs.existsSync(path) ? fs.readFileSync(path) : Buffer.alloc(0)\n          var buffer\n          if (options && (options.packname || options.author)) {\n            buffer = await writeExifImg(buff, options)\n          } else {\n            buffer = await imageToWebp(buff)\n          }\n          await corvo.sendMessage(jid, { sticker: { url: buffer }, ...options })\n          return buffer\n        }\n\n        corvo.sendInteractiveTXT = async (idChat, mainText = '', footerText = '', quotedMessage = {}, buttonsParams = {}) => {\n          try {\n            await corvo.relayMessage(idChat, { interactiveMessage: { body: { text: mainText }, footer: { text: footerText }, contextInfo: quotedMessage, nativeFlowMessage: buttonsParams } }, {});\n          } catch (errorMessage) {\n            await reply(String(errorMessage));\n          }\n        }\n\n        corvo.sendInteractiveIMG = async (imageDir, ChatID, definedText = '', footer = '', contextMessageInfo = {}, buttonsParams = {}) => {\n          try {\n            create = await prepareWAMessageMedia({ image: fs.readFileSync(imageDir) }, { upload: corvo.waUploadToServer });\n            imageCreate = create.imageMessage;\n            await corvo.relayMessage(ChatID, { interactiveMessage: { header: { hasMediaAttachment: true, imageMessage: imageCreate }, headerType: 'IMAGE', body: { text: definedText }, footer: { text: footer }, contextInfo: contextMessageInfo, nativeFlowMessage: buttonsParams } }, {});\n          } catch (errorMessage) {\n            return reply(String(errorMessage));\n          }\n        }\n\n        var getallcases = () => {\n          findindex = fs.readFileSync("corvo.js").toString().match(/case\s+'(.+?)'/g)\n          cstt = []\n          for (i of findindex) {\n            cstt.push(i.split(`'`)[1])\n          }\n          return cstt\n        }\n\n        var allCases = getallcases();\n\n        var getSimilarity = require(`./ARQUIVES/js/similaridade.js`)\n\n        var rmLetras = (txt) => {\n          return txt.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, "");\n        }\n\n        var similarityCmd = (txt) => {\n          getsmlrt = getSimilarity(allCases, txt, prefix)\n          if (rmLetras(getsmlrt.nome).includes(`${prefix}ᴍᴇɴᴜ`)) return [{ comando: getsmlrt.nome, porcentagem: getsmlrt.porcentagem }]\n          return [{ comando: prefix + getsmlrt.nome, porcentagem: Number(getsmlrt.porcentagem).toFixed(1) }]\n        }\n\n\n        var { registrarNoPrefix, removerNoPrefix, getComandoNoPrefix, registrarFigSticker, removerFigSticker, getComandoFig, listarFigStickers, listarNoPrefix } = require('./ARQUIVES/funcoes/command.js')\n\n        var Corvosticker = Object.keys(info.message)[0] == "stickerMessage" ? info.message.stickerMessage.fileSha256.toString('base64') : ""\n\n        if (Corvosticker) {\n          var comandoFig = getComandoFig(Corvosticker)\n          if (comandoFig && typeof comandoFig === 'string') {\n            isCmd = true\n            command = comandoFig.toLowerCase()\n          }\n        }\n\n        var NoPrefixCorvo = budy2.trim().slice(0).trim().split(" ")[0].trim().toLocaleLowerCase()\n\n        var comandoRegistrado = getComandoNoPrefix(NoPrefixCorvo)\n        if (comandoRegistrado && typeof comandoRegistrado === 'string') {\n          isCmd = true\n          command = comandoRegistrado.toLowerCase()\n        }\n\n\n        // ===== SISTEMA MODO AI =====\n        global.modoAI = global.modoAI || {}\n\n        var modoai = global.modoAI[from] || false\n\n        //======================================\\\n        if (!global.menuAzAtivos) global.menuAzAtivos = {};\n        if (!isCmd && global.menuAzAtivos[sender]) {\n          var escolha = body.trim();\n          if (escolha === '0') {\n            delete global.menuAzAtivos[sender];\n            return reply(`*ᴏᴋ ꜱᴇɴʜᴏʀ(ᴀ), ᴄᴀꜱᴏ ǫᴜᴇɪʀᴀ ꜱᴀʙᴇʀ ꜱᴇ ᴏꜱ ᴄᴏᴍᴀɴᴅᴏꜱ ꜰᴏʀᴀᴍ ᴀᴛɪᴠᴏꜱ, ᴜꜱᴇ →『 ${prefix}status 』 ᴇ ᴏʟʜᴇ ᴀᴛᴇɴᴛᴀᴍᴇɴᴛᴇ ᴛᴏᴅᴀꜱ ᴀꜱ ᴏᴩᴄᴏᴇꜱ 🙇‍♂️*`);\n          }\n          var opcoes = { '1': 'antiaudio', '2': 'antivideo', '3': 'antiimg', '4': 'autosticker', '5': 'bemvindo', '6': 'bemvindo2', '7': 'antilink', '8': 'antilinkgp', '9': 'antilinkeasy', '10': 'anticatalogo', '11': 'antistatus', '12': 'antifake', '13': 'anticontato', '14': 'antiloc', '15': 'antiddd', '16': 'so_adm', '17': 'x9adm', '18': 'autototext', '19': 'ativic', '20': 'autodl', '21': 'multiprefixo', '22': 'antinotas', '23': 'antipalavra', '24': 'antipalavrao', '25': 'modobn', '26': 'modocoins', '27': 'antipagamento' };\n          var cmd = opcoes[escolha];\n          if (cmd) {\n            command = cmd;\n            isCmd = true;\n            prefix = '';\n          }\n        }\n\n        var enviar = {\n          msg: {\n            grupo: "❌ Esse comando só funciona em grupo.",\n            adm: "❌ Apenas admins podem usar esse comando.",\n            donosmt: "❌ Apenas o dono pode usar esse comando."\n          }\n        };\n\n        async function gerarAttpQuote(texto) {\n          var txt = String(texto)\n            .replace(/\s*\|\s*/g, "\n")\n            .trim();\n\n          var body = {\n            type: "quote",\n            format: "png",\n            backgroundColor: "#ffffff",\n            width: 512,\n            height: 512,\n\n            // quanto maior = texto maior\n            scale: 9,\n\n            messages: [\n              {\n                entities: [],\n                avatar: false,\n                from: {\n                  id: 1,\n                  name: "" // ← remove o "ATTP" de cima\n                },\n                text: txt,\n                replyMessage: {}\n              }\n            ]\n          };\n\n          var res = await axios.post(\n            "https://bot.lyo.su/quote/generate",\n            body,\n            {\n              headers: { "Content-Type": "application/json" },\n              timeout: 20000\n            }\n          );\n\n          return Buffer.from(res.data.result.image, "base64");\n        }\n\n        async function baixarMp4Buffer(url) {\n          var r = await axios.get(url, {\n            responseType: "arraybuffer",\n            timeout: 120000, // 2 min\n            maxRedirects: 5,\n            headers: { "User-Agent": "Mozilla/5.0" },\n            validateStatus: (s) => s >= 200 && s < 400,\n            maxContentLength: Infinity,\n            maxBodyLength: Infinity\n          });\n\n          var ct = String(r.headers?.["content-type"] || "");\n          // se vier html, não é mp4 direto\n          if (ct.includes("text/html")) return null;\n\n          return Buffer.from(r.data);\n        }\n\n        // ===== Helpers City/RPG (cole acima do switch) =====\n        // var isRpgOn já existe globalmente no topo do arquivo (linha 73).\n        const hasCityUser = (jid) => sabrpg?.some(u => u.id === jid);\n\n        const getCityIndex = (jid) => sabrpg?.findIndex(u => u.id === jid);\n\n        const writeJSON = (path, data) => fs.writeFileSync(path, JSON.stringify(data, null, 2));\n\n        //MODO AI====\\\n\n        if (global.modoAI?.[from]) {\n\n          var msg = body.toLowerCase()\n\n          if (global.modoAI?.[from]) {\n\n            var msg = body.toLowerCase()\n\n            if (msg.includes("tocar")) {\n\n              // [REMOVIDO - já importado globalmente] var axios = require('axios')\n\n              var musica = msg.replace(/corvo|tocar|,/g, "").trim()\n\n              if (!musica) return reply("🎵 Diga o nome da música.")\n\n              try {\n\n                await reagir(from, "🔎")\n\n                // pesquisar música\n                var busca = await axios.get(`https://api.sandrohost.com.br/api-sandro/pesquisa_ytb?nome=${encodeURIComponent(musica)}&apikey=${API_SANDRO_MD}`)\n\n                var item = busca.data?.[0] || busca.data?.result?.[0] || busca.data?.data?.[0]\n\n                if (!item) return reply("❌ Música não encontrada")\n\n                var titulo = item.titulo || item.title\n                var tempo = item.tempo || item.duration\n                var thumb = item.thumb || item.thumbnail || item.image\n\n                // enviar thumb\n                if (thumb) {\n                  await corvo.sendMessage(from, {\n                    image: { url: thumb },\n                    caption: `🎧 *PLAY*\n\n🎵 ${titulo}\n⏱️ ${tempo}\n\n⬇️ Enviando áudio...`\n                  }, { quoted: info })\n                }\n\n                // link do áudio\n                var audioUrl = `https://api.sandrohost.com.br/api-sandro/play?nome_url=${encodeURIComponent(musica)}&apikey=${API_SANDRO_MD}`\n\n                // enviar áudio\n                await corvo.sendMessage(from, {\n                  audio: { url: audioUrl },\n                  mimetype: "audio/mpeg"\n                }, { quoted: info })\n\n                await reagir(from, "✅")\n\n              } catch (e) {\n                console.log("PLAY IA ERRO:", e)\n                reply("❌ erro ao baixar música")\n              }\n\n              return\n            }\n          }\n\n          // BEIJO IA\n          if (\n            msg.includes("beijar") ||\n            msg.includes("dar um beijo")\n          ) {\n\n            if (!isGroup) return reply(mess.onlyGroup())\n            if (!isModobn) return reply(mess.onlyGroupFun(prefix))\n\n            var ctx = info?.message?.extendedTextMessage?.contextInfo || {}\n            var mencoes = Array.isArray(ctx.mentionedJid) ? ctx.mentionedJid : []\n\n            var alvo = mencoes[0] || ctx.participant\n\n            if (!alvo) {\n              return reply("*🌟 Marque alguém (@) ou responda a mensagem da pessoa para beijar!*")\n            }\n\n            var autor = info?.key?.participant || sender\n\n            await corvo.sendMessage(from, {\n              video: { url: 'https://files.catbox.moe/9qyfv3.mp4' },\n              gifPlayback: true,\n              caption: `💋 @${autor.split('@')[0]} beijou @${alvo.split('@')[0]}! 😳💖`,\n              mentions: [autor, alvo]\n            }, { quoted: selo })\n\n            return\n          }\n\n          // FAZER FIGURINHA\n          if (msg.includes("fazer figurinha") || msg.includes("criar figurinha") || msg.includes("f figurinha")) {\n\n            var RSM = info.message?.extendedTextMessage?.contextInfo?.quotedMessage\n            var boij2 = RSM?.imageMessage || info.message?.imageMessage || RSM?.viewOnceMessageV2?.message?.imageMessage || info.message?.viewOnceMessageV2?.message?.imageMessage || info.message?.viewOnceMessage?.message?.imageMessage || RSM?.viewOnceMessage?.message?.imageMessage\n\n            var boij = RSM?.videoMessage || info.message?.videoMessage || RSM?.viewOnceMessageV2?.message?.videoMessage || info.message?.viewOnceMessageV2?.message?.videoMessage || info.message?.viewOnceMessage?.message?.videoMessage || RSM?.viewOnceMessage?.message?.videoMessage\n\n            if (boij2) {\n\n              var pack = `${pushname}`\n              var author2 = `${pushname}`\n\n              owgi = await getFileBuffer(boij2, 'image')\n\n              var encmediaa = await sendImageAsSticker2(corvo, from, owgi, selo, {\n                packname: pack,\n                author: author2,\n                contextInfo: NkChannelKk\n              })\n\n              await DLT_FL(encmediaa)\n\n              return\n            }\n\n            else if (boij && boij.seconds < 11) {\n\n              var pack = `${pushname}`\n              var author2 = `${pushname}`\n\n              owgi = await getFileBuffer(boij, 'video')\n\n              var encmedia = await sendVideoAsSticker2(corvo, from, owgi, selo, {\n                packname: pack,\n                author: author2,\n                contextInfo: NkChannelKk\n              })\n\n              await DLT_FL(encmedia)\n\n              return\n            }\n\n            else {\n              return reply("*Envie ou marque uma imagem ou vídeo de até 9.9s para fazer figurinha.*")\n            }\n\n          }\n\n          var textoAI = body.toLowerCase()\n\n          // 🔒 FECHAR GRUPO\n          if (textoAI.includes("fechar grupo") || textoAI.includes("fecha grupo")) {\n\n            if (!isGroupAdmins) return reply(mess.onlyAdmins())\n            if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin())\n\n            try {\n\n              await corvo.groupSettingUpdate(from, 'announcement')\n\n              reply(`╭────────────────\n│ 🔒 *GRUPO FECHADO*\n│\n│ Agora apenas administradores\n│ podem enviar mensagens.\n╰────────────────`)\n\n            } catch (e) {\n              console.error('erro ao fechar grupo:', e)\n              reply('*Erro ao fechar o grupo.* ❌')\n            }\n\n          }\n\n\n          // 🔓 ABRIR GRUPO\n          if (textoAI.includes("abrir grupo") || textoAI.includes("abre grupo")) {\n\n            if (!isGroupAdmins) return reply(mess.onlyAdmins())\n            if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin())\n\n            try {\n\n              await corvo.groupSettingUpdate(from, 'not_announcement')\n\n              reply(`╭────────────────\n│ 🔓 *GRUPO ABERTO*\n│\n│ Todos agora podem\n│ enviar mensagens.\n╰────────────────`)\n\n            } catch (e) {\n              console.error('erro ao abrir grupo:', e)\n              reply('*Erro ao abrir o grupo.* ❌')\n            }\n\n          }\n\n          // BANIR\n          if (msg.includes("corvo, banir") || msg.includes("kick") || msg.includes("remover")) {\n\n            if (!isGroupAdmins && !SoDono) return reply(mess.onlyAdmins())\n            if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin())\n\n            if (!menc_os2) return reply("🌟 Marque o usuário para remover.")\n\n            await corvo.sendMessage(from, {\n              text: `*ᴄᴇʀᴛᴏ... ʀᴇᴍᴏᴠɪ ᴏ(ᴀ) @${menc_os2.split("@")[0]}*`,\n              contextInfo: {\n                mentionedJid: [menc_os2]\n              }\n            }, { quoted: info })\n\n            await corvo.groupParticipantsUpdate(from, [encontrarJidReal(menc_os2)], "remove")\n\n            return\n          }\n\n\n          if (global.modoAI?.[from]) {\n\n            var msg = body.toLowerCase()\n\n            // PROMOVER\n            if (msg.includes("promover") || msg.includes("promove")) {\n\n              if (!isGroup) return\n              if (!isGroupAdmins) return\n              if (!isBotGroupAdmins) return\n\n              if (!menc_os2) return reply("🌟 marque a pessoa que deseja promover")\n\n              await corvo.sendMessage(from, {\n                text: `*@${menc_os2.split("@")[0]} foi promovido a administrador com sucesso 🙇‍♂️*`,\n                mentions: [menc_os2]\n              }, { quoted: info })\n\n              await corvo.groupParticipantsUpdate(from, [encontrarJidReal(menc_os2)], "promote")\n\n              return\n            }\n\n            // REBAIXAR\n            if (msg.includes("rebaixar") || msg.includes("rebaixa")) {\n\n              if (!isGroup) return\n              if (!isGroupAdmins) return\n              if (!isBotGroupAdmins) return\n\n              if (!menc_os2) return reply("🌟 marque a pessoa que deseja rebaixar")\n\n              await corvo.sendMessage(from, {\n                text: `*@${menc_os2.split("@")[0]} foi rebaixado para membro comum 🙇‍♂️*`,\n                mentions: [menc_os2]\n              }, { quoted: info })\n\n              await corvo.groupParticipantsUpdate(from, [encontrarJidReal(menc_os2)], "demote")\n\n              return\n            }\n\n          }\n\n          // METADINHA IA\n          if (msg.includes("enviar metadinha")) {\n\n            try {\n\n              await reagir(from, "💑")\n\n              // fonte das imagens\n              var data = await fetchJson(\n                'https://raw.githubusercontent.com/iamriz7/kopel_/main/kopel.json'\n              )\n\n              if (!Array.isArray(data) || data.length === 0) {\n                return reply("❌ Não consegui pegar as metadinhas agora.")\n              }\n\n              var pick = data[Math.floor(Math.random() * data.length)]\n\n              var maleUrl = pick.male\n              var femaleUrl = pick.female\n\n              if (!maleUrl || !femaleUrl) {\n                console.log("[METADINHA] Item inválido:", pick)\n                return reply("❌ Erro ao carregar as imagens.")\n              }\n\n              // preparar mídias\n              var maleMedia = await prepareWAMessageMedia(\n                { image: { url: maleUrl } },\n                { upload: corvo.waUploadToServer }\n              )\n\n              var femaleMedia = await prepareWAMessageMedia(\n                { image: { url: femaleUrl } },\n                { upload: corvo.waUploadToServer }\n              )\n\n              var msg2 = generateWAMessageFromContent(from, {\n                interactiveMessage: {\n                  body: { text: '*Resultados da metadinha* 💝 ↴' },\n                  carouselMessage: {\n                    cards: [\n                      {\n                        header: {\n                          hasMediaAttachment: true,\n                          imageMessage: maleMedia.imageMessage\n                        },\n                        body: { text: "• Perfil Masculino 🕊️" },\n                        footer: { text: NomeDoBot },\n                        nativeFlowMessage: { buttons: [] }\n                      },\n                      {\n                        header: {\n                          hasMediaAttachment: true,\n                          imageMessage: femaleMedia.imageMessage\n                        },\n                        body: { text: "• Perfil Feminino 🌸" },\n                        footer: { text: NomeDoBot },\n                        nativeFlowMessage: { buttons: [] }\n                      }\n                    ]\n                  }\n                }\n              }, { quoted: info })\n\n              await corvo.relayMessage(from, msg2.message, { messageId: msg2.key.id })\n\n            } catch (e) {\n              console.log("ERRO METADINHA IA:", e)\n              reply("❌ erro ao buscar metadinha")\n            }\n\n            return\n          }\n\n          // CLIMA IA\n          if (msg.includes("me diga o clima de") || msg.includes("me manda a previsão do tempo")) {\n\n            // [REMOVIDO - já importado globalmente] var axios = require("axios")\n\n            try {\n\n              var cidade = msg\n                .replace(/corvo|clima|tempo|,/g, "")\n                .trim()\n                .toLowerCase()\n\n              // converter siglas dos estados\n              cidade = cidade\n                .replace(/ ac$/i, " Acre, Brazil")\n                .replace(/ al$/i, " Alagoas, Brazil")\n                .replace(/ ap$/i, " Amapá, Brazil")\n                .replace(/ am$/i, " Amazonas, Brazil")\n                .replace(/ ba$/i, " Bahia, Brazil")\n                .replace(/ ce$/i, " Ceará, Brazil")\n                .replace(/ df$/i, " Distrito Federal, Brazil")\n                .replace(/ es$/i, " Espírito Santo, Brazil")\n                .replace(/ go$/i, " Goiás, Brazil")\n                .replace(/ ma$/i, " Maranhão, Brazil")\n                .replace(/ mt$/i, " Mato Grosso, Brazil")\n                .replace(/ ms$/i, " Mato Grosso do Sul, Brazil")\n                .replace(/ mg$/i, " Minas Gerais, Brazil")\n                .replace(/ pa$/i, " Pará, Brazil")\n                .replace(/ pb$/i, " Paraíba, Brazil")\n                .replace(/ pr$/i, " Paraná, Brazil")\n                .replace(/ pe$/i, " Pernambuco, Brazil")\n                .replace(/ pi$/i, " Piauí, Brazil")\n                .replace(/ rj$/i, " Rio de Janeiro, Brazil")\n                .replace(/ rn$/i, " Rio Grande do Norte, Brazil")\n                .replace(/ rs$/i, " Rio Grande do Sul, Brazil")\n                .replace(/ ro$/i, " Rondônia, Brazil")\n                .replace(/ rr$/i, " Roraima, Brazil")\n                .replace(/ sc$/i, " Santa Catarina, Brazil")\n                .replace(/ sp$/i, " São Paulo, Brazil")\n                .replace(/ se$/i, " Sergipe, Brazil")\n                .replace(/ to$/i, " Tocantins, Brazil")\n\n              if (!cidade) return reply("🌦️ Diga a cidade.\nEx: corvo clima Passos MG")\n\n              await reagir(from, "🌦️")\n\n              var API = "318753fcc5224cdab3f195827261303"\n\n              var { data } = await axios.get(\n                `http://api.weatherapi.com/v1/current.json?key=${API}&q=${encodeURIComponent(cidade)}&lang=pt`\n              )\n\n              var icone = "https:" + data.current.condition.icon\n\n              await corvo.sendMessage(from, {\n                image: { url: icone },\n                caption:\n                  `🌦️ *CLIMA AGORA*\n\n📍 ${data.location.name}, ${data.location.region} - ${data.location.country}\n\n${data.current.condition.text}\n\n🌡️ Temperatura: ${data.current.temp_c}°C\n🥵 Sensação térmica: ${data.current.feelslike_c}°C\n\n💧 Umidade: ${data.current.humidity}%\n🌬️ Vento: ${data.current.wind_kph} km/h`\n              }, { quoted: info })\n\n            } catch (e) {\n              console.log("ERRO CLIMA IA:", e)\n              reply("❌ erro ao buscar clima")\n            }\n\n            return\n          }\n\n          // ===== MENU NO MODO AI =====\n          global.modoAI = global.modoAI || {}\n          var modoai = global.modoAI[from] || false\n\n          var textoMsg = (msg || "").trim().toLowerCase()\n          var abrirMenuIA =\n            textoMsg === "abrir menu" ||\n            textoMsg === "corvo, abrir menu"\n\n          if (modoai && abrirMenuIA) {\n\n            try {\n              reagir(from, "🕸️");\n\n              var caminhoVideo = "./DADOS DO CORVO/INFO_CORVO/LOGOS/fotomenu.mp4";\n              var caminhoImagem = "./DADOS DO CORVO/INFO_CORVO/LOGOS/fotomenu.png";\n\n              var mediaMenu;\n\n              if (fs.existsSync(caminhoVideo)) {\n                mediaMenu = await prepareWAMessageMedia({\n                  video: { url: caminhoVideo },\n                  mimetype: "video/mp4",\n                  gifPlayback: true\n                }, { upload: corvo.waUploadToServer });\n              } else {\n                mediaMenu = await prepareWAMessageMedia({\n                  image: { url: caminhoImagem }\n                }, { upload: corvo.waUploadToServer });\n              }\n\n              var listaMenus = {\n                title: "⃞🦇 MENU-LISTAS ⃞🦇",\n                sections: [\n                  {\n                    title: "⃞💠 MENUS ⃞💠",\n                    highlight_label: "popular",\n                    rows: [\n                      { header: "⃞💠 MENU PRINCIPAL ⃞💠", title: "Comandos gerais", id: prefix + "menu_principal_lista" },\n                      { header: "⃞💠 MENU ADM ⃞💠", title: "Comandos de admin", id: prefix + "menu_adm_lista" },\n                      { header: "⃞💠 MENU DONO ⃞💠", title: "Comandos do dono", id: prefix + "menu_dono_lista" },\n                      { header: "⃞💠 MENU LOGO ⃞💠", title: "TextPro / Logos", id: prefix + "menu_logo_lista" },\n                      { header: "⃞💠 MENU ALTERADORES ⃞💠", title: "Áudio / Vídeo", id: prefix + "menu_alt_lista" },\n                      { header: "⃞💠 MENU BN ⃞💠", title: "Jogos / brincadeiras", id: prefix + "menu_bn_lista" },\n                      { header: "⃞💠 EFEITOS IMG ⃞💠", title: "Efeitos em imagem", id: prefix + "menu_efeitos_lista" }\n                    ]\n                  },\n                  {\n                    title: "⃞💠 CATEGORIAS ⃞💠",\n                    rows: [\n                      { header: "⃞💠 INFOS / CHECKS ⃞💠", title: "Ping, perfil, etc", id: prefix + "menu_infos_lista" },\n                      { header: "⃞💠 DOWNLOAD ⃞💠", title: "Músicas / vídeos", id: prefix + "menu_download_lista" },\n                      { header: "⃞💠 PESQUISAS ⃞💠", title: "Clima, wiki, etc", id: prefix + "menu_pesquisa_lista" },\n                      { header: "⃞💠 INTELIGENCIAS ⃞💠", title: "GPT, imagine", id: prefix + "menu_ia_lista" },\n                      { header: "⃞💠 FIGURINHAS ⃞💠", title: "Sticker / toimg", id: prefix + "menu_figu_lista" },\n                      { header: "⃞💠 RANDOMS ⃞💠", title: "Extras diversos", id: prefix + "menu_random_lista" }\n                    ]\n                  }\n                ]\n              };\n\n              var botoes = [\n                { name: "single_select", buttonParamsJson: JSON.stringify(listaMenus) },\n                {\n                  name: "cta_url", buttonParamsJson: JSON.stringify({\n                    display_text: "🕸️ 𝙲𝙰𝙽𝙰𝙻 𝚄𝙿𝙳𝙰𝚃𝙴 🕸️",\n                    url: "https://whatsapp.com/channel/seu_canal",\n                    merchant_url: "https://whatsapp.com/channel/seu_canal"\n                  })\n                }\n              ];\n\n              var time = new Date().toLocaleTimeString("pt-BR", {\n                timeZone: "America/Sao_Paulo",\n                hour: "2-digit",\n                minute: "2-digit",\n                second: "2-digit"\n              });\n\n              var versao = require("./package.json").version;\n\n              var textok = `╭✘━𑁁━፝֟🌀₊˚✮⊰𝆺𝅥✿𝆺𝅥 ⊱✮˚₊‧🌀━𑁁━✘╮\n⌇🔘 Usuário: ${pushname}\n⌇🔘 Bot: ${NomeDoBot}\n⌇🔘 Cargo: ${isGroupAdmins ? "adm" : "membro"}\n⌇🔘 Dono: ${ownerName}\n⌇🔘 Prefixo: ${prefix}\n⌇🔘 Versão: ${versao}\n⌇🔘 Hora: ${time}\n╰✘━𑁁━፝֟🌀₊˚✮⊰𝆺𝅥✿𝆺𝅥 ⊱✮˚₊‧🌀━𑁁━✘╯`;\n\n              var carouselMessage = {\n                cards: [{\n                  header: {\n                    hasMediaAttachment: true,\n                    ...(mediaMenu.videoMessage\n                      ? { videoMessage: mediaMenu.videoMessage }\n                      : { imageMessage: mediaMenu.imageMessage })\n                  },\n                  headerType: mediaMenu.videoMessage ? "VIDEO" : "IMAGE",\n                  body: { text: textok },\n                  footer: { text: "ᴇsᴄᴏʟʜᴀ ᴀ ᴏᴘçãᴏ ᴀʙᴀɪxᴏ" },\n                  nativeFlowMessage: { buttons: botoes }\n                }]\n              };\n\n              var msgMenu = generateWAMessageFromContent(from, {\n                interactiveMessage: {\n                  contextInfo: {\n                    participant: sender,\n                    quotedMessage: { conversation: "░⃟⃛🕸️ ᴀǫᴜɪ ᴇsᴛᴀ sᴇᴜ ᴍᴇɴᴜ ░⃟⃛🕸️" }\n                  },\n                  body: { text: "*🕸️ ᴍᴇɴᴜ ɪɴᴛᴇʀᴀᴛɪᴠᴏ 🕸️*" },\n                  carouselMessage\n                }\n              }, {});\n\n              await corvo.relayMessage(from, msgMenu.message, { messageId: msgMenu.key.id });\n\n            } catch (e) {\n              console.log("MENU AI ERRO:", e)\n            }\n\n          }\n\n          // 👀 REVELAR VISUALIZAÇÃO ÚNICA NO PV\n          if (\n            textoAI.includes("revelar") ||\n            textoAI.includes("abrir visualização única") ||\n            textoAI.includes("abrir visualizacao unica") ||\n            textoAI.includes("open") ||\n            textoAI.includes("gtnaa")\n          ) {\n            try {\n              var pv = sender\n              var quoted = info.message?.extendedTextMessage?.contextInfo?.quotedMessage\n\n              if (!quoted) return\n\n              // IMAGEM\n              var image =\n                quoted?.imageMessage ||\n                quoted?.viewOnceMessage?.message?.imageMessage ||\n                quoted?.viewOnceMessageV2?.message?.imageMessage\n\n              if (image) {\n                var buffImage = await getFileBuffer(image, 'image')\n\n                await corvo.sendMessage(pv, {\n                  image: buffImage,\n                  caption: image.caption || ''\n                }, { quoted: selo })\n\n                return\n              }\n\n              // VÍDEO\n              var video =\n                quoted?.videoMessage ||\n                quoted?.viewOnceMessage?.message?.videoMessage ||\n                quoted?.viewOnceMessageV2?.message?.videoMessage\n\n              if (video) {\n                var buffVideo = await getFileBuffer(video, 'video')\n\n                await corvo.sendMessage(pv, {\n                  video: buffVideo,\n                  mimetype: video.mimetype || 'video/mp4',\n                  caption: video.caption || ''\n                }, { quoted: selo })\n\n                return\n              }\n\n              // ÁUDIO\n              var audio =\n                quoted?.audioMessage ||\n                quoted?.viewOnceMessageV2Extension?.message?.audioMessage ||\n                quoted?.viewOnceMessage?.message?.audioMessage\n\n              if (audio) {\n                var buffAudio = await getFileBuffer(audio, 'audio')\n\n                await corvo.sendMessage(pv, {\n                  audio: buffAudio,\n                  mimetype: audio.mimetype || 'audio/mpeg',\n                  ptt: audio.ptt || false\n                }, { quoted: selo })\n\n                return\n              }\n\n            } catch (e) {\n              console.log('ERRO MODOAI REVELAR:', e)\n            }\n          }\n\n          // 🔎 PESQUISAR TIKTOK\n          if (body.toLowerCase().includes("corvo, pesquisar") && body.toLowerCase().includes("corvo, pesquisa")) {\n\n            try {\n\n              // [REMOVIDO - já importado globalmente] var axios = require('axios')\n\n              var q = body.split("pesquisa")[1]?.trim()\n\n              if (!q) return reply("❌ Exemplo: corvo pesquisa tiktok akame")\n\n              await reagir(from, "🔎")\n\n              var res = await axios.get(`https://www.tikwm.com/api/feed/search?keywords=${encodeURIComponent(q)}&count=10&cursor=0`)\n\n              var videos = res.data.data.videos.slice(0, 10)\n\n              if (!videos.length) return reply("❌ Nenhum resultado encontrado.")\n\n              var medias = await Promise.all(\n                videos.map(v =>\n                  prepareWAMessageMedia(\n                    { video: { url: v.play } },\n                    { upload: corvo.waUploadToServer }\n                  )\n                )\n              )\n\n              var cards = videos.map((v, i) => ({\n                header: {\n                  hasMediaAttachment: true,\n                  videoMessage: medias[i].videoMessage\n                },\n                body: {\n                  text:\n                    `👤 Autor: ${v.author.nickname}\n\n❤️ Likes: ${v.digg_count}\n💬 Comentários: ${v.comment_count}`\n                },\n                footer: { text: NomeDoBot },\n                nativeFlowMessage: { buttons: [] }\n              }))\n\n              var msg = generateWAMessageFromContent(from, {\n                interactiveMessage: {\n                  body: { text: "🔎 TIKTOK SEARCH RESULTS" },\n                  carouselMessage: { cards }\n                }\n              }, { quoted: info })\n\n              await corvo.relayMessage(from, msg.message, { messageId: msg.key.id })\n\n            } catch (e) {\n\n              console.log("[TIKTOK AI ERROR]", e)\n\n              reply("❌ erro ao pesquisar tiktok")\n\n            }\n\n          }\n\n\n        }\n\n        //EVAL CMD KK\n        if (budy.startsWith('<')) {\n          try {\n            if (info.key.fromMe) return;\n            if (!SoDono && !isnit && !issupre && !ischyt) return;\n            console.log('[', colors.cyan('EVAL'), ']', colors.yellow(moment(info.messageTimestamp * 1000).format('DD/MM HH:mm:ss')), colors.green(q));\n            var res = JSON.stringify(eval(q.slice(1)), null, '\t');\n            return reply(res);\n          } catch (e) {\n            return reply(String(e));\n          }\n        }\n        if (budy2.startsWith('(>')) {\n          try {\n            if (info.key.fromMe) return;\n            if (!isnit && !issupre && !ischyt) return;\n            var konsol = q.slice(3);\n            Return = (sul) => {\n              var sat = JSON.stringify(sul, null, 2);\n              var bang = sat === undefined ? util.format(sul) : util.format(sat);\n              return reply(bang);\n            };\n            reply(util.format(eval(`;(async () => { ${konsol} })()`)));\n          } catch (e) {\n            reply(String(e));\n          }\n        }\n        if (budy.startsWith('$')) {\n          if (info.key.fromMe) return;\n          if (!SoDono && !isnit && !issupre && !ischyt) return;\n          var comando = q.slice(1).trim();\n          exec(comando, (err, stdout, stderr) => {\n            if (err) return reply(String(err));\n            if (stderr) return reply(String(stderr));\n            if (stdout) return reply(String(stdout));\n            reply(`*ᴏ ᴄᴏᴍᴀɴᴅᴏ → 「 ${comando} 」 ꜰᴏɪ ᴇxᴇᴄᴜᴛᴀᴅᴏ ᴄᴏᴍ ꜱᴜᴄᴇꜱꜱᴏ ꜱᴇɴʜᴏʀ(ᴀ) 🙇‍♂️*`);\n          });\n        }\n\n        // RESPOSTAS RÁPIDAS (sempre ativo)\n\n        if (isGroup && info.message?.extendedTextMessage?.contextInfo?.quotedMessage) {\n\n          var txt = body?.toLowerCase().trim()\n          if (txt.startsWith(prefix)) txt = txt.slice(prefix.length).trim()\n\n          var quoted = info.message.extendedTextMessage.contextInfo\n          var msgId = quoted.stanzaId\n          var participant = quoted.participant\n\n          // APAGAR MENSAGEM COM "d" (só admin ou dono)\n          if (txt === "d") {\n\n            if (!isGroupAdmins && !SoDono) return\n            if (!isBotGroupAdmins) return\n\n            // Tentar apagar a mensagem quotada\n            try {\n              await corvo.sendMessage(from, { delete: { remoteJid: from, fromMe: false, id: msgId, participant: participant } });\n            } catch (_e1) {\n              try {\n                await corvo.sendMessage(from, { delete: { remoteJid: from, fromMe: true, id: msgId, participant: participant } });\n              } catch (_e2) {}\n            }\n\n            // Fallback: messageStore\n            var _sm = messageStore?.[msgId] || global.messageStore?.[msgId];\n            if (_sm?.key) {\n              try { await corvo.sendMessage(from, { delete: _sm.key }); } catch (_se) {}\n            }\n\n            // Apagar o /d\n            setTimeout(() => {\n              corvo.sendMessage(from, { delete: info.key }).catch(() => {});\n            }, 500);\n\n            return\n          }\n        }\n\n\n\n        //=============ANTIFT==============\\\n\n        global.antiFt = global.antiFt || {}\n\n        if (\n          isGroup &&\n          isBotGroupAdmins &&\n          !isGroupAdmins &&\n          !SoDono &&\n          global.antiFt[from] === true &&\n          (\n            type === 'imageMessage' ||\n            info.message?.imageMessage ||\n            info.message?.viewOnceMessage?.message?.imageMessage ||\n            info.message?.viewOnceMessageV2?.message?.imageMessage\n          )\n        ) {\n          try {\n            await corvo.sendMessage(from, {\n              delete: {\n                remoteJid: from,\n                fromMe: false,\n                id: info.key.id,\n                participant: sender\n              }\n            })\n          } catch (e) {\n            console.log('ERRO ANTIFT:', e)\n          }\n          return\n        }\n\n        if (\n          isGroup &&\n          isBotGroupAdmins &&\n          dataGp[0]?.antiemoji === true &&\n          body &&\n          !SoDono &&\n          !itsMe\n        ) {\n          var emojiRegex = /[\p{Emoji_Presentation}\p{Extended_Pictographic}]/gu\n\n          if (emojiRegex.test(body)) {\n            try {\n              await corvo.sendMessage(from, {\n                delete: {\n                  remoteJid: from,\n                  fromMe: false,\n                  id: info.key.id,\n                  participant: sender\n                }\n              })\n              return\n            } catch (e) {\n              console.log('ERRO ANTIEMOJI:', e)\n            }\n          }\n        }\n\n        if (\n          isGroup &&\n          isAutorepo &&\n          !isCmd &&\n          !info.key.fromMe &&\n          body &&\n          body.trim().length > 1 &&\n          !isAntiFlood &&\n          !isBotoff\n        ) {\n          try {\n            var respostaIA = await responderIA(\n              body,\n              "responda curto, natural, como alguém normal de grupo do WhatsApp"\n            )\n\n            var respostaStr = typeof respostaIA === 'string' ? respostaIA : (respostaIA ? String(respostaIA) : '')\n            if (respostaStr && respostaStr.trim()) {\n              await reply(respostaStr)\n              return\n            }\n          } catch (e) {\n            console.log('ERRO AUTOREPO:', e)\n          }\n        }\n\n        // ===== ANTIFLOOD =====\n\n        global.antiFlood = global.antiFlood || {}\n\n        if (\n          isGroup &&\n          isBotGroupAdmins &&\n          !isGroupAdmins &&\n          !SoDono &&\n          dataGp[0]?.limitec?.active === true\n        ) {\n          var tempoLimite = Number(dataGp[0].limitec.tempo || 0)\n          var maxMsgs = Number(dataGp[0].limitec.quantidade || 0)\n\n          // CORREÇÃO: só processar se os valores forem válidos (> 0)\n          if (tempoLimite > 0 && maxMsgs > 0) {\n\n            if (!dataGp[0].limitec.usuarios) dataGp[0].limitec.usuarios = {}\n\n            var agora = Date.now()\n\n            if (!dataGp[0].limitec.usuarios[sender]) {\n              dataGp[0].limitec.usuarios[sender] = {\n                msgs: 1,\n                tempo: agora\n              }\n            } else {\n              var diff = (agora - dataGp[0].limitec.usuarios[sender].tempo) / 1000\n\n              if (diff <= tempoLimite) {\n                dataGp[0].limitec.u