1 : 0\n          })\n        } else {\n          var indnum = numbersIds.indexOf(sender)\n          var userData = countMessage[ind].numbers[indnum]\n          if (type !== "stickerMessage") {\n            userData.messages = (userData.messages || 0) + (isCmd ? 0 : 1)\n            userData.cmd_messages = (userData.cmd_messages || 0) + (isCmd ? 1 : 0)\n            userData.aparelho = adivinha || userData.aparelho || 'desconhecido'\n          }\n          userData.figus = (userData.figus || 0) + (type === "stickerMessage" ? 1 : 0)\n          userData.imagens = (userData.imagens || 0) + (isImage ? 1 : 0)\n          userData.videos = (userData.videos || 0) + (isVideo ? 1 : 0)\n          userData.audios = (userData.audios || 0) + (isAudio ? 1 : 0)\n          userData.documentos = (userData.documentos || 0) + ((isQuotedDocument || type === "documentMessage") ? 1 : 0)\n        }\n        fs.writeFileSync('./DADOS DO CORVO/INFO_CORVO/media/countmsg.json', JSON.stringify(countMessage))\n\n        function limparContadorUsuariosFora(from, groupMembers) {\n          var ind = countMessage.findIndex(i => i.groupId === from)\n          if (ind === -1) return 0\n          var contador = countMessage[ind].numbers\n          var membrosDoGrupo = []\n          for (var m of groupMembers) {\n            var id = jidNormalizedUser(typeof m === 'string' ? m : m.id)\n            membrosDoGrupo.push(id)\n          }\n          var removidos = 0\n          for (var i = contador.length - 1; i >= 0; i--) {\n            var idContador = jidNormalizedUser(contador[i].id)\n            if (!membrosDoGrupo.includes(idContador)) {\n              contador.splice(i, 1)\n              removidos++\n            }\n          }\n\n          return removidos\n        }\n\n        var getGroupIndex = (groupId) => countMessage.findIndex(g => g.groupId === groupId);\n        var pickRandom = (arr) => {\n          return arr[Math.floor(Math.random() * arr.length)]\n        }\n\n        if (body != undefined) { /* Créditos: @Nkzin */\n          if (!JSON.stringify(pushnames).includes(botNumber)) {\n            pushnames.push({ id: botNumber, nick: NomeDoBot });\n            fs.writeFileSync("./DADOS DO CORVO/usuarios/users.json", JSON.stringify(pushnames, null, 2));\n          }\n          if (!JSON.stringify(pushnames).includes(sender)) {\n            pushnames.push({ id: sender, nick: pushname });\n            fs.writeFileSync("./DADOS DO CORVO/usuarios/users.json", JSON.stringify(pushnames, null, 2));\n          } else {\n            pushnames[pushnames.map(i => i.id).indexOf(sender)].nick = pushname\n            fs.writeFileSync("./DADOS DO CORVO/usuarios/users.json", JSON.stringify(pushnames, null, 2));\n          }\n        }\n\n        //======================================\\\n\n        var CorvoAluguel = './ARQUIVES/tictactoe/grupos_com_aluguel.json'\n        var gruposAutorizados = []\n        if (!fs.existsSync(CorvoAluguel)) fs.writeFileSync(CorvoAluguel, JSON.stringify([]))\n        gruposAutorizados = JSON.parse(fs.readFileSync(CorvoAluguel))\n        function salvarGrupos() {\n          fs.writeFileSync(CorvoAluguel, JSON.stringify(gruposAutorizados, null, 2))\n        }\n        function ativarAluguelGrupo(from, dias = 0, horas = 0) {\n          var agora = new Date()\n          var expiraEm = new Date(agora.getTime() + (dias * 24 + horas) * 60 * 60 * 1000)\n\n          var jaExiste = gruposAutorizados.find(g => g.id === from)\n          if (!jaExiste) {\n            gruposAutorizados.push({ id: from, expiraEm: expiraEm.toISOString() })\n            salvarGrupos()\n          } else {\n            jaExiste.expiraEm = expiraEm.toISOString()\n            salvarGrupos()\n          }\n        }\n        async function desativarAluguelGrupo(from) {\n          try {\n            gruposAutorizados = gruposAutorizados.filter(g => g.id !== from)\n            salvarGrupos()\n            var meta = await corvo.groupMetadata(from)\n            var midia = carregarMidia("fotomenu")\n            var msg = { caption: mess.aluguel(ownerNumber, NumeroDoBot, NomeDoBot), contextInfo: { ...NkChannelKk }, mentions: groupAdmins }\n            if (midia.type === "video") {\n              msg.video = midia.data\n              msg.gifPlayback = true\n            } else if (midia.type === "image") {\n              msg.image = midia.data\n            } else {\n              msg.text = msg.caption\n            }\n            await corvo.sendMessage(from, msg)\n          } catch (e) {\n            console.log("Erro ao desativar aluguel:", e)\n          }\n        }\n\n\n        function isGrupoAutorizado(from) {\n          var grupo = gruposAutorizados.find(g => g.id === from)\n          if (!grupo) return false\n\n          var agora = new Date()\n          var expira = new Date(grupo.expiraEm)\n\n          if (agora > expira) {\n            desativarAluguelGrupo(from)\n            return false\n          }\n          return true\n        }\n\n\n        if (isGroup && isModoAluguel && !SoDono && !isGrupoAutorizado(from)) {\n          return\n        }\n\n        //======(ANTI-PORNOGRAFIA + ANTI-GORE)========\\\n        if (isAntiPorn && isBotGroupAdmins && !isGroupAdmins && !info.key.fromMe) {\n          var _isMediaPorn = false;\n          var _mediaType = null;\n          var _mediaObj = null;\n\n          // Detectar tipo de mídia\n          if (type === 'imageMessage') {\n            _mediaType = 'image';\n            _mediaObj = info.message?.imageMessage;\n          } else if (type === 'videoMessage') {\n            _mediaType = 'video';\n            _mediaObj = info.message?.videoMessage;\n          } else if (type === 'stickerMessage') {\n            _mediaType = 'image';\n            _mediaObj = info.message?.stickerMessage;\n          }\n\n          if (_mediaType && _mediaObj) {\n            try {\n              // Baixar a mídia\n              var _dlType = type === 'stickerMessage' ? 'sticker' : _mediaType;\n              var _dlFunc = typeof downloadContentFromMessage === 'function' ? downloadContentFromMessage : require('@itsliaaa/baileys').downloadContentFromMessage;\n              var _stream = await _dlFunc(_mediaObj, _dlType);\n              var _mediaBuf = Buffer.from([]);\n              for await (var _chunk of _stream) {\n                _mediaBuf = Buffer.concat([_mediaBuf, _chunk]);\n              }\n\n              if (_mediaBuf.length > 0) {\n                // Para vídeo, pegar só um frame (primeiro KB como thumbnail se disponível)\n                var _bufToAnalyze = _mediaBuf;\n                \n                // Se for vídeo e tiver thumbnail, usar a thumbnail (mais rápido)\n                if (_mediaType === 'video' && _mediaObj.jpegThumbnail) {\n                  _bufToAnalyze = Buffer.from(_mediaObj.jpegThumbnail, 'base64');\n                }\n\n                // Limitar tamanho para API (max 5MB)\n                if (_bufToAnalyze.length > 5 * 1024 * 1024) {\n                  _bufToAnalyze = _bufToAnalyze.slice(0, 5 * 1024 * 1024);\n                }\n\n                // Enviar para API de detecção NSFW\n                var _FormData = require('form-data');\n                var _fd = new _FormData();\n                var _ext = type === 'stickerMessage' ? 'webp' : (_mediaType === 'video' ? 'jpg' : 'jpg');\n                _fd.append('image', _bufToAnalyze, { filename: `check.${_ext}`, contentType: `image/jpeg` });\n\n                var _nsfwResult = await axios.post('https://demo.api4ai.cloud/nsfw/v1/results', _fd, {\n                  headers: _fd.getHeaders(),\n                  timeout: 15000\n                }).catch(e => null);\n\n                if (_nsfwResult?.data?.results?.[0]?.entities?.[0]?.classes) {\n                  var _classes = _nsfwResult.data.results[0].entities[0].classes;\n                  var _nsfwScore = _classes.nsfw || 0;\n                  var _safeScore = _classes.safe || 0;\n\n                  console.log('[ANTIPORN] Score NSFW:', _nsfwScore, 'Safe:', _safeScore, 'Type:', type, 'User:', sender);\n\n                  // Se score NSFW > 0.6, considerar pornografia/conteúdo explícito\n                  if (_nsfwScore > 0.6) {\n                    _isMediaPorn = true;\n                  }\n                }\n              }\n            } catch (_pornErr) {\n              console.log('[ANTIPORN] Erro ao analisar:', _pornErr.message || _pornErr);\n            }\n\n            if (_isMediaPorn) {\n              // Apagar mensagem\n              try {\n                await corvo.sendMessage(from, { delete: info.key });\n              } catch (_delErr) {}\n\n              // Avisar no grupo\n              var _pornUser = pushname || sender.split('@')[0];\n              await corvo.sendMessage(from, {\n                text: `⚠️🔞 *CONTEÚDO PROIBIDO DETECTADO!*\n\n` +\n                      `👤 Usuário: @${sender.split('@')[0]}\n` +\n                      `📛 Tipo: ${type === 'imageMessage' ? 'Imagem' : type === 'videoMessage' ? 'Vídeo' : 'Figurinha'}\n\n` +\n                      `❌ Conteúdo pornográfico/explícito não é permitido neste grupo.\n` +\n                      `🚫 O usuário será removido.`,\n                mentions: [sender]\n              }, { quoted: selo });\n\n              // Remover usuário\n              if (JSON.stringify(groupMembers).includes(sender)) {\n                await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove');\n              }\n              return;\n            }\n          }\n        }\n\n        //======(ANTI-IMAGEM)========\\\n        if (isAntiImg && isBotGroupAdmins && type == 'imageMessage') {\n          if (info.key.fromMe) return;\n          if (isGroupAdmins) return;\n          if (dataGp[0].legenda_imagem == "0") {\n            await corvo.sendMessage(from, { text: "Por favor, envie uma imagem com legenda." }, { quoted: selo });\n            if (IS_DELETE) {\n              setTimeout(async () => {\n                if (groupMembers.find(member => member.id === sender)) {\n                  await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove');\n                }\n              }, 1000);\n            }\n          }\n        }\n\n        //======(ANTI-STICKER)========\\\n        if (isAntiSticker && !isGroupAdmins && isBotGroupAdmins && type == 'stickerMessage') {\n          if (info.key.fromMe) return;\n          var isAdminOrOwner = groupMembers.find(member => member.id === sender && (member.isAdmin || member.isOwner));\n          if (isAdminOrOwner) return;\n          if (IS_DELETE) {\n            setTimeout(async () => {\n              await corvo.sendMessage(from, { delete: info.key });\n            }, 500);\n          }\n          if (!JSON.stringify(groupMembers).includes(sender)) return;\n          await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove');\n        }\n\n        //============[ ANTI DOCUMENTO ]============\\\n\n        if (Antidoc && isBotGroupAdmins && !isGroupAdmins && type == 'documentMessage') {\n          if (info.key.fromMe) return\n          if (isGroupAdmins) return await corvo.sendMessage(from, { text: mess.messageProhibitedDetAdmin() }, { quoted: selo })\n          if (IS_DELETE) {\n            setTimeout(async () => {\n              await corvo.sendMessage(from, { delete: info.key })\n            }, 500)\n          }\n          if (!JSON.stringify(groupMembers).includes(sender)) return\n          await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove')\n        }\n\n\n        if (isUrl(PR_String) && isAntiLinkEasy && !isGroupAdmins && !isListaBrancaG && isBotGroupAdmins && !info.key.fromMe) {\n          if (Procurar_String.includes("chat.whatsapp.com")) {\n            link_dgp = await corvo.groupInviteCode(from)\n            if (Procurar_String.match(link_dgp)) return reply('*[-⚠-] ᴅɪᴠᴜʟɢᴏᴜ ʟɪɴᴋ? ɪʀᴇɪ ᴀᴘᴀɢᴀʀ.*');\n          }\n          if (isCmd && isTrueFalse) return\n          if (IS_DELETE) {\n            setTimeout(async () => {\n              await corvo.sendMessage(from, { delete: info.key });\n            }, 500);\n          }\n        }\n\n        // ANTI NOTAS FAKES ==================>\n        if (isAntiNotas && budy2.toString().match(/(💳|💎|💸|💵|💷|💶|🪙|💰|🤑|⚖️)/gi) && isBotGroupAdmins && !isGroupAdmins && !SoDono && !info.message?.reactionMessage?.text && budy2.length > 20) {\n          var verificar = budy2.toString().match(/(💳|💎|💸|💵|💷|💶|🪙|💰|🤑|⚖️)/gi);\n          if (verificar && budy.length < 100) return\n          if (IS_DELETE) {\n            setTimeout(async () => {\n              await corvo.sendMessage(from, { delete: info.key });\n            }, 500);\n          }\n          if (!JSON.stringify(groupMembers).includes(sender)) return\n          await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove');\n        }\n\n        //FINALZIN ===========================>\n        function remover(id, usu) {\n          corvo.groupParticipantsUpdate(id, [encontrarJidReal(usu)], "remove")\n        }\n        //======(ANTI-VIDEO)========\\\n        if (isAntiVid && isBotGroupAdmins && type == 'videoMessage') {\n          if (isGroupAdmins) return await corvo.sendMessage(from, { text: mess.messageProhibitedDetAdmin() }, { quoted: selo });\n          if (dataGp[0].legenda_video == "0") {\n            await corvo.sendMessage(from, { text: mess.messageProhibitedDetUser() }, { quoted: selo });\n          } else {\n            await corvo.sendMessage(from, { text: dataGp[0].legenda_video }, { quoted: selo });\n          }\n          if (IS_DELETE) {\n            setTimeout(async () => {\n              await corvo.sendMessage(from, { delete: info.key });\n            }, 500);\n          }\n          if (!JSON.stringify(groupMembers).includes(sender)) return\n          await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove');\n        }\n\n        //======(ANTI-AUDIO)=======\\\n        if (isAntiAudio && isBotGroupAdmins && type == 'audioMessage') {\n          if (isGroupAdmins) return await corvo.sendMessage(from, { text: mess.messageProhibitedDetAdmin() }, { quoted: selo });\n          await corvo.sendMessage(from, { text: mess.messageProhibitedDetUser() }, { quoted: selo });\n          if (IS_DELETE) {\n            setTimeout(async () => {\n              await corvo.sendMessage(from, { delete: info.key });\n            }, 500);\n          }\n          if (!JSON.stringify(groupMembers).includes(sender)) return\n          await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove');\n        }\n\n        //========(ANTI_LIGAR)========\\\n        if (!isGroup && isAnticall) {\n          corvo.ws.on('CB:call', async (B) => {\n            if (B.content[0].tag == 'offer') {\n              var numero = B.content[0].attrs['call-creator'];\n              await corvo.updateBlockStatus(numero, "block");\n            }\n          });\n        }\n\n        //========(ANTI STATUS)========\\\n        if (isGroup && dataGp[0]?.antistatus === true && isBotGroupAdmins && !SoDono && !isGroupAdmins) {\n          var strMsg = JSON.stringify(info.message || {});\n          if (strMsg.includes('groupStatusMentionMessage') || strMsg.includes('groupStatusMessageV2') || strMsg.includes('status@broadcast')) {\n            await corvo.sendMessage(from, {\n              text: `*ᴜꜱᴜᴀʀɪᴏ ʙᴀɴɪᴅᴏ ᴩᴏʀ ᴩᴏꜱᴛᴀʀ ꜱᴛᴀᴛᴜꜱ ɴᴏ ɢʀᴜᴩᴏ* 🗣️`,\n              mentions: [sender]\n            }, { quoted: selo })\n            await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove')\n            // Limpar metadata + apagar mensagem\n            setTimeout(async () => {\n              try {\n                // Tentar limpar via chatModify primeiro\n                try {\n                  await corvo.chatModify({ clear: { messages: [{ id: info.key.id, fromMe: info.key.fromMe, timestamp: info.messageTimestamp }] } }, from);\n                } catch (_ce) {}\n                // Depois tentar apagar normalmente\n                var _dk = { ...info.key };\n                await corvo.sendMessage(from, { delete: _dk });\n              } catch (_e) {\n                try {\n                  var _dk2 = { ...info.key, fromMe: !info.key.fromMe };\n                  await corvo.sendMessage(from, { delete: _dk2 });\n                } catch (_e2) {}\n              }\n            }, 1000)\n          }\n        }\n\n        //========(ANTI PAGAMENTO)========\\\n        if (isGroup && dataGp[0]?.antipagamento === true && isBotGroupAdmins && !SoDono && !isGroupAdmins) {\n          var strMsg2 = JSON.stringify(info.message || {});\n          var isPagamento = false;\n          // Detectar todos os tipos de mensagem de pagamento\n          if (strMsg2.includes('requestPaymentMessage') || strMsg2.includes('sendPaymentMessage') || strMsg2.includes('paymentInviteMessage')) isPagamento = true;\n          // Detectar por campos de pagamento no payload\n          if (strMsg2.includes('currencyCodeIso4217') || strMsg2.includes('amount1000')) isPagamento = true;\n          if (isPagamento) {\n            await corvo.sendMessage(from, {\n              text: `*💰 ᴜꜱᴜᴀʀɪᴏ ʀᴇᴍᴏᴠɪᴅᴏ ᴩᴏʀ ᴇɴᴠɪᴀʀ ᴩᴀɢᴀᴍᴇɴᴛᴏ ɴᴏ ɢʀᴜᴩᴏ* 🚫`,\n              mentions: [sender]\n            }, { quoted: selo })\n            await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove')\n            // Limpar metadata + apagar mensagem de pagamento\n            setTimeout(async () => {\n              try {\n                // Limpar via chatModify primeiro (necessário para pagamentos)\n                try {\n                  await corvo.chatModify({ clear: { messages: [{ id: info.key.id, fromMe: info.key.fromMe, timestamp: info.messageTimestamp }] } }, from);\n                } catch (_ce) {}\n                // Depois tentar apagar\n                var _dk = { ...info.key };\n                if (info.key?.addressingMode) _dk.addressingMode = info.key.addressingMode;\n                await corvo.sendMessage(from, { delete: _dk });\n              } catch (_e) {\n                try {\n                  var _dk2 = { ...info.key, fromMe: !info.key.fromMe };\n                  if (info.key?.addressingMode) _dk2.addressingMode = info.key.addressingMode;\n                  await corvo.sendMessage(from, { delete: _dk2 });\n                } catch (_e2) {}\n              }\n            }, 1000)\n          }\n        }\n\n        //========(ANTI BOT)========\\\n        if (isGroup && dataGp[0]?.antibot === true && !info.key.fromMe && isBotGroupAdmins && !SoDono && !isGroupAdmins) {\n          var isBotMessage = false;\n          var msgId = info.key.id;\n          if ((msgId.length === 16 && msgId.startsWith("BAE5")) ||\n            (msgId.length === 22 && msgId.startsWith("3EB0")) ||\n            (msgId.length === 20 && msgId.startsWith("B24E"))) {\n            isBotMessage = true;\n          }\n          if (isBotMessage) {\n            await corvo.sendMessage(from, {\n              text: `*🤖 ʙᴏᴛ ɪɴᴠᴀꜱᴏʀ ᴅᴇᴛᴇᴄᴛᴀᴅᴏ ᴇ ʀᴇᴍᴏᴠɪᴅᴏ ᴄᴏᴍ ꜱᴜᴄᴇꜱꜱᴏ!*`,\n              mentions: [sender]\n            }, { quoted: selo });\n            await corvo.groupParticipantsUpdate(from, [encontrarJidReal(sender)], 'remove');\n            setTimeout(() => {\n              corvo.sendMessage(from, { delete: info.key });\n            }, 1000);\n          }\n        }\n\n\n\n        /* ANTIPV1 - Este anti pv bloqueia aqueles que encaminham mensagem no pv do bot.. */\n        var USUARIOS_BLOQ = []\n        if (isAntiPv && !USUARIOS_BLOQ.includes(sender)) {\n          if (!isGroup && !SoDono && !isnit && !isVip) {\n            await sleep(2500)\n            reply(msgantipv1.replace('#nome#', pushname))\n            setTimeout(async () => {\n              await corvo.updateBlockStatus(sender, 'block')\n            }, 2000)\n          }\n          USUARIOS_BLOQ.push(sender);\n        }\n\n        /* ANTIPV2 - Vai floodar o privado do usuário que encaminhar a mensagem no privado.. */\n        var MSG_ANTPV2_ENC = []\n        if (!isGroup && !isVip && !SoDono && !isnit && !issupre && !ischyt && !info.key.fromMe && isAntiPv2 && !MSG_ANTPV2_ENC.includes(sender)) {\n          MSG_ANTPV2_ENC.push(sender);\n          return reply(msgantipv2)\n        }\n\n        /* ANTIPV3 - Ignora todos os que falam ou usam os comandos no privado, exceto user vip e o proprietário atual do bot. */\n        if (!isGroup && !isVip && !SoDono && !info.key.fromMe && isAntiPv3) return\n\n        //====================================\\\n\n        var VerificarJSON = (json, value) => {\n          if (JSON.stringify(json).includes(value)) return true\n          return false\n        }\n\n        var RG_SCOINS = JSON.parse(fs.readFileSync("./DADOS DO CORVO/func/coins.json"));\n\n        var isModoCoins = isGroup ? dataGp[0].isModoCoins : undefined\n\n        var ID_G_COINS = RG_SCOINS.findIndex(i => i.grupo === from)\n        var ID_USU_COINS = RG_SCOINS[ID_G_COINS]?.usus?.findIndex(i => i.id === sender);\n\n        function CoinsUpdate(index) {\n          fs.writeFileSync("./DADOS DO CORVO/func/coins.json", JSON.stringify(index, null, 2) + "\n")\n        }\n\n        var SYSTEM_COIN = {\n\n          AdicionarCoins: async function (user, quant) {\n            CoinsUser_ = RG_SCOINS[ID_G_COINS].usus.find(i => i.id === user);\n            if (!CoinsUser_) return reply("O(a) usuário(a) nunca enviou uma mensagem neste grupo! Então não é possível adicionar ou transferir coins à um membro que não possuí registro!");\n            CoinsUser_["coins"] += quant;\n            CoinsUpdate(RG_SCOINS);\n          },\n\n          transferCoins: async function (transferidor, recebidor, quantidade) {\n            DM_ = RG_SCOINS[ID_G_COINS].usus.find(i => i.id === transferidor)\n            DM_2 = RG_SCOINS[ID_G_COINS].usus.find(i => i.id === recebidor)\n            if ((DM_?.coins || 0) < quantidade) return mention(`A quantidade que você tem é inferior a que você deseja transferir ao usuário: @${recebidor.split("@")[0]}`)\n            if (!DM_2) return mention(`O(a) usuário(a) '@${recebidor.split("@")[0]}' nunca enviou uma mensagem neste grupo! Então não é possível adicionar ou transferir coins à um usuário não registrado no meu sistema!`);\n            DM_["coins"] -= quantidade;\n            DM_2["coins"] += quantidade;\n            CoinsUpdate(RG_SCOINS);\n          },\n\n          Adicionar_2: async function (A, Q, X, X2) {\n            DM_ = RG_SCOINS[ID_G_COINS].usus.find(i => i.id === A);\n            if (!DM_) return reply("O(a) usuário(a) nunca enviou uma mensagem neste grupo! Então não é possível atualizar a carteira!");\n            DM_["coins"] += Q;\n            DM_[X] = X2\n            CoinsUpdate(RG_SCOINS);\n          },\n\n          RemoverCoins: async function (user, quant) {\n            CoinsUser = RG_SCOINS[ID_G_COINS].usus.find(i => i.id === user)\n            if (!CoinsUser) return reply("O(a) usuário(a) nunca enviou uma mensagem neste grupo! Então não é possível remover coins de membro inativo que não possuí registro!");\n            if ((CoinsUser?.coins || 0) < quant) return reply(`O usuário possuí '${CoinsUser?.coins} N-Coins', este valor não é suficiente para realizar a transação de remoção de ${quant}.`);\n            CoinsUser["coins"] -= quant;\n            CoinsUpdate(RG_SCOINS);\n          },\n\n          VerificarCampo: function (user, parameter) {\n            return RG_SCOINS[ID_G_COINS].usus.find(i => i.id === user)[parameter] || null;\n          },\n\n        }\n\n        if (isModoCoins && isGroup && isBotGroupAdmins && VRF_JSON_GRUPO && !info.key.fromMe) {\n\n          if (!RG_SCOINS.some(i => i.grupo === from)) {\n            RG_SCOINS.push({ grupo: from, usus: [{ id: sender, coins: 0, data: 0, chances: { cassino: 0, minerar: 0 } }] })\n            CoinsUpdate(RG_SCOINS);\n          } else if (RG_SCOINS.some(i => i.grupo === from) && !RG_SCOINS[ID_G_COINS]?.usus?.some(i => i?.id === sender)) {\n            RG_SCOINS[ID_G_COINS].usus.push({ id: sender, coins: 0, data: 0, chances: { cassino: 0, minerar: 0 } })\n            CoinsUpdate(RG_SCOINS);\n          }\n\n          if (!info.message?.reactionMessage?.text && dattofc != SYSTEM_COIN.VerificarCampo(sender, "data")) {\n            await mention(mess.coins(tempo, sender, prefix));\n            SYSTEM_COIN.Adicionar_2(sender, 50, "data", dattofc);\n            RG_US = RG_SCOINS[ID_G_COINS].usus.find(i => i.id === sender);\n            Object.assign(RG_US.chances, { "cassino": 0, "minerar": 0 });\n            CoinsUpdate(RG_SCOINS);\n          }\n        }\n\n        if (isGroup && fs.existsSync(`./DADOS DO CORVO/grupos/games/anagrama/${from}.json`)) {\n          var dataA = JSON.parse(fs.readFileSync(`./DADOS DO CORVO/grupos/games/anagrama/${from}.json`))\n          if (budy.slice(0, 4).toUpperCase() == dataA.palavraOriginal.slice(0, 4).toUpperCase() && budy.toUpperCase() != dataA.palavraOriginal) return reply('Está perto...')\n          if (budy.toUpperCase() == dataA.palavraOriginal) {\n            await corvo.sendMessage(from, { text: mess.acert(pushname, dataA, resposta) }, { "mentionedJid": [sender] }, { quoted: selo })\n            await SYSTEM_COIN.AdicionarCoins(sender, 5);\n            fs.unlinkSync(`./DADOS DO CORVO/grupos/games/anagrama/${from}.json`)\n            setTimeout(async () => {\n              fs.writeFileSync(`./DADOS DO CORVO/grupos/games/anagrama/${from}.json`, `${JSON.stringify(palavrasANA[Math.floor(Math.random() * palavrasANA.length)])}`)\n              dataAB = JSON.parse(fs.readFileSync(`./DADOS DO CORVO/grupos/games/anagrama/${from}.json`))\n              corvo.sendMessage(from, { text: mess.anagrama(shuffle, dataAB) }, { quoted: selo })\n            }, 5000)\n          }\n        }\n\n        if (isGroup && fs.existsSync(`./DADOS DO CORVO/grupos/games/quiz-animais/${from}.json`)) {\n          var dQ = JSON.parse(fs.readFileSync(`./DADOS DO CORVO/grupos/games/quiz-animais/${from}.json`))\n       